<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- CSR ACTIVITIES VIEWS -->
    <record id="view_ecosphere_csr_activity_tree" model="ir.ui.view">
        <name>ecosphere.csr.activity.tree</name>
        <model>ecosphere.csr.activity</model>
        <arch type="xml">
            <tree string="CSR Campaigns" decoration-info="status == 'open'" decoration-success="status == 'completed'" decoration-muted="status == 'cancelled'">
                <field name="title"/>
                <field name="category"/>
                <field name="date"/>
                <field name="budget" sum="Total Budget"/>
                <field name="points_reward"/>
                <field name="participant_count"/>
                <field name="status" widget="badge" decoration-warning="status == 'draft'" decoration-info="status == 'open'" decoration-success="status == 'completed'"/>
            </tree>
        </arch>
    </record>

    <record id="view_ecosphere_csr_activity_kanban" model="ir.ui.view">
        <name>ecosphere.csr.activity.kanban</name>
        <model>ecosphere.csr.activity</model>
        <arch type="xml">
            <kanban default_group_by="status">
                <field name="title"/>
                <field name="category"/>
                <field name="date"/>
                <field name="points_reward"/>
                <field name="status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="title"/></strong>
                                <div>
                                    <span class="badge badge-secondary"><field name="category"/></span>
                                </div>
                                <div class="text-muted">
                                    Date: <field name="date"/>
                                </div>
                                <div>
                                    Reward: <strong class="text-success"><field name="points_reward"/> XP</strong>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </arch>
    </record>

    <record id="view_ecosphere_csr_activity_form" model="ir.ui.view">
        <name>ecosphere.csr.activity.form</name>
        <model>ecosphere.csr.activity</model>
        <arch type="xml">
            <form string="CSR Campaign Dashboard">
                <header>
                    <button name="action_open" string="Open Registration" type="object" states="draft" class="oe_highlight"/>
                    <button name="action_complete" string="Complete Campaign" type="object" states="open" class="oe_highlight"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,open,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="title" placeholder="Campaign Name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="budget"/>
                            <field name="points_reward"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="participants" string="Registered Employees">
                            <field name="participation_ids">
                                <tree editable="bottom">
                                    <field name="employee_id"/>
                                    <field name="proof"/>
                                    <field name="points_earned" readonly="1"/>
                                    <field name="status" widget="badge" decoration-info="status == 'draft'" decoration-success="status == 'approved'" decoration-danger="status == 'rejected'"/>
                                    <button name="action_approve" string="Approve" type="object" icon="fa-check-circle" states="draft" class="text-success"/>
                                    <button name="action_reject" string="Reject" type="object" icon="fa-times-circle" states="draft" class="text-danger"/>
                                </tree>
                            </field>
                        </page>
                        <page name="desc" string="Objectives Description">
                            <field name="description" placeholder="Describe environmental and community goals..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </arch>
    </record>

    <record id="action_ecosphere_csr" model="ir.actions.act_window">
        <name>CSR Campaigns</name>
        <res_model>ecosphere.csr.activity</res_model>
        <view_mode>tree,kanban,form</view_mode>
        <help type="html">
            <p class="o_view_nocontent_smiling_face">
                Launch a CSR activity for employee volunteerism.
            </p>
        </help>
    </record>

    <menuitem id="menu_ecosphere_csr_actions" name="CSR Campaigns" parent="menu_ecosphere_social" action="action_ecosphere_csr" sequence="10"/>


    <!-- SUSTAINABILITY TRAINING VIEWS -->
    <record id="view_ecosphere_training_tree" model="ir.ui.view">
        <name>ecosphere.sustainability.training.tree</name>
        <model>ecosphere.sustainability.training</model>
        <arch type="xml">
            <tree string="Training Courses" editable="bottom">
                <field name="name"/>
                <field name="duration_hours"/>
                <field name="active"/>
            </tree>
        </arch>
    </record>

    <record id="action_ecosphere_trainings" model="ir.actions.act_window">
        <name>Sustainability Training Courses</name>
        <res_model>ecosphere.sustainability.training</res_model>
        <view_mode>tree</view_mode>
    </record>

    <menuitem id="menu_ecosphere_training_actions" name="Training Courses" parent="menu_ecosphere_social" action="action_ecosphere_trainings" sequence="20"/>


    <!-- TRAINING PARTICIPATION TRACKER -->
    <record id="view_ecosphere_training_part_tree" model="ir.ui.view">
        <name>ecosphere.training.participation.tree</name>
        <model>ecosphere.training.participation</model>
        <arch type="xml">
            <tree string="Training Records" editable="bottom">
                <field name="employee_id"/>
                <field name="training_id"/>
                <field name="completion_pct" widget="progressbar"/>
                <field name="certificate_no"/>
                <field name="date_completed"/>
                <field name="status" widget="badge" decoration-warning="status == 'enrolled'" decoration-success="status == 'completed'"/>
            </tree>
        </arch>
    </record>

    <record id="action_ecosphere_training_part" model="ir.actions.act_window">
        <name>Training Progress logs</name>
        <res_model>ecosphere.training.participation</res_model>
        <view_mode>tree</view_mode>
    </record>

    <menuitem id="menu_ecosphere_training_part_actions" name="Employee Learning Logs" parent="menu_ecosphere_social" action="action_ecosphere_training_part" sequence="30"/>
</odoo>
