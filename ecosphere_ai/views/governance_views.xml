<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ESG POLICIES VIEWS -->
    <record id="view_ecosphere_policy_tree" model="ir.ui.view">
        <name>ecosphere.policy.tree</name>
        <model>ecosphere.policy</model>
        <arch type="xml">
            <tree string="Policies List" decoration-success="status == 'active'" decoration-muted="status == 'expired'">
                <field name="name"/>
                <field name="category"/>
                <field name="version"/>
                <field name="date_published"/>
                <field name="date_expiry"/>
                <field name="ack_percentage" widget="progressbar"/>
                <field name="status" widget="badge" decoration-warning="status == 'draft'" decoration-success="status == 'active'" decoration-danger="status == 'expired'"/>
            </tree>
        </arch>
    </record>

    <record id="view_ecosphere_policy_form" model="ir.ui.view">
        <name>ecosphere.policy.form</name>
        <model>ecosphere.policy</model>
        <arch type="xml">
            <form string="ESG Policy Card">
                <header>
                    <button name="action_activate" string="Publish Policy" type="object" states="draft" class="oe_highlight"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,expired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Policy Title..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category"/>
                            <field name="version"/>
                        </group>
                        <group>
                            <field name="date_published"/>
                            <field name="date_expiry"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="content" string="Policy Text Content">
                            <field name="content" placeholder="Provide full business rules and environmental compliance expectations..."/>
                        </page>
                        <page name="acks" string="Employee Sign-Off Matrix">
                            <field name="acknowledgement_ids" readonly="1">
                                <tree>
                                    <field name="employee_id"/>
                                    <field name="date_acknowledged"/>
                                    <field name="status" widget="badge" decoration-warning="status == 'pending'" decoration-success="status == 'accepted'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </arch>
    </record>

    <record id="action_ecosphere_policies" model="ir.actions.act_window">
        <name>Governance Policies</name>
        <res_model>ecosphere.policy</res_model>
        <view_mode>tree,form</view_mode>
    </record>

    <menuitem id="menu_ecosphere_policy_actions" name="ESG Policies" parent="menu_ecosphere_governance" action="action_ecosphere_policies" sequence="10"/>


    <!-- ESG AUDITS VIEWS -->
    <record id="view_ecosphere_audit_tree" model="ir.ui.view">
        <name>ecosphere.audit.tree</name>
        <model>ecosphere.audit</model>
        <arch type="xml">
            <tree string="Compliance Audits">
                <field name="name"/>
                <field name="auditor"/>
                <field name="audit_date"/>
                <field name="scope"/>
                <field name="status" widget="badge" decoration-warning="status == 'planned'" decoration-info="status == 'in_progress'" decoration-success="status == 'completed'"/>
            </tree>
        </arch>
    </record>

    <record id="view_ecosphere_audit_form" model="ir.ui.view">
        <name>ecosphere.audit.form</name>
        <model>ecosphere.audit</model>
        <arch type="xml">
            <form string="Audit Record">
                <header>
                    <button name="action_complete" string="Approve Audit Report" type="object" states="planned,in_progress" class="oe_highlight"/>
                    <field name="status" widget="statusbar" statusbar_visible="planned,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="auditor"/>
                            <field name="audit_date"/>
                        </group>
                        <group>
                            <field name="scope"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Auditing Findings">
                            <field name="report_summary" placeholder="Write internal findings regarding raw materials, logistics checks, and governance compliance issues..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </arch>
    </record>

    <record id="action_ecosphere_audits" model="ir.actions.act_window">
        <name>ESG Compliance Audits</name>
        <res_model>ecosphere.audit</res_model>
        <view_mode>tree,form</view_mode>
    </record>

    <menuitem id="menu_ecosphere_audit_actions" name="Compliance Audits" parent="menu_ecosphere_governance" action="action_ecosphere_audits" sequence="20"/>


    <!-- COMPLIANCE ISSUES VIEWS -->
    <record id="view_ecosphere_compliance_tree" model="ir.ui.view">
        <name>ecosphere.compliance.issue.tree</name>
        <model>ecosphere.compliance.issue</model>
        <arch type="xml">
            <tree string="Governance Violations" decoration-danger="status == 'overdue'" decoration-success="status == 'resolved'">
                <field name="title"/>
                <field name="severity" widget="badge" decoration-danger="severity == 'critical'" decoration-warning="severity == 'high'" decoration-info="severity == 'medium'"/>
                <field name="owner_id"/>
                <field name="due_date"/>
                <field name="status" widget="badge" decoration-danger="status in ['open','overdue']" decoration-warning="status == 'under_review'" decoration-success="status == 'resolved'"/>
            </tree>
        </arch>
    </record>

    <record id="view_ecosphere_compliance_form" model="ir.ui.view">
        <name>ecosphere.compliance.issue.form</name>
        <model>ecosphere.compliance.issue</model>
        <arch type="xml">
            <form string="Compliance Issue Remediation Card">
                <header>
                    <button name="action_review" string="Submit for Review" type="object" states="open,overdue" class="oe_highlight"/>
                    <button name="action_resolve" string="Mark as Resolved" type="object" states="under_review" class="oe_highlight"/>
                    <field name="status" widget="statusbar" statusbar_visible="open,under_review,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="title" placeholder="Compliance concern / anomaly name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="severity"/>
                            <field name="owner_id"/>
                        </group>
                        <group>
                            <field name="due_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="resolution" string="Resolution Log">
                            <field name="resolution_notes" placeholder="Detail action steps taken to resolve audits findings and mitigate ESG risks..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </arch>
    </record>

    <record id="action_ecosphere_compliance" model="ir.actions.act_window">
        <name>Compliance Issues Ledger</name>
        <res_model>ecosphere.compliance.issue</res_model>
        <view_mode>tree,form</view_mode>
    </record>

    <menuitem id="menu_ecosphere_compliance_actions" name="Compliance Issues" parent="menu_ecosphere_governance" action="action_ecosphere_compliance" sequence="30"/>
</odoo>
